# Line-ending normalization so the repo is portable across OSes.
# Default: let git handle text, store LF in the repo.
* text=auto eol=lf

# Shell scripts MUST be LF — CRLF breaks the bash shebang (`bad interpreter`).
*.sh   text eol=lf

# PowerShell / batch are Windows-native — keep CRLF on checkout.
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary assets — never munge line endings.
*.png  binary
*.jpg  binary
*.ico  binary
*.db   binary
*.node binary
*.exe  binary
