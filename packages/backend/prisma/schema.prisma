generator client {
  provider = "prisma-client-js"
  // Non-dot output so electron-builder bundles it (it strips node_modules/.prisma).
  // Ships inside backend/dist/generated/prisma via the build copy step.
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  path        String    @unique
  type        String?   // e.g. "node", "python", "unknown"
  packageMgr  String?   // e.g. "npm", "pnpm", "yarn", "pip", "poetry"
  status      String    @default("registered") // registered | analyzed | error
  codeMapEmbed Boolean  @default(false) // when true, Claude sessions for this project get the codebase-memory-mcp (Code Map) MCP server attached
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  commands    RunCommand[]
  runs        Run[]
  analyses    Analysis[]
  eodEntries  EodEntry[]
  releases    Release[]
}

model RunCommand {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label      String   // e.g. "dev", "install", "build"
  command    String   // e.g. "npm run dev"
  cwd        String?  // defaults to project.path if null
  isDefault  Boolean  @default(false)
  source     String   @default("detected") // detected (from analyze) | custom (user-added)
  createdAt  DateTime @default(now())

  runs       Run[]
}

model Run {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commandId   String?
  command     RunCommand? @relation(fields: [commandId], references: [id], onDelete: SetNull)
  kind        String      @default("command") // shell | claude | command
  name        String?     // user-renamed tab label (persisted)
  dockOpen    Boolean     @default(false)     // is this an open tab in the workspace (restored on reopen)
  pid         Int?
  claudeSessionId String?  // kind='claude' only: the NARUKAMI-assigned Claude session UUID (--session-id). Own id, kept separate from any native-CLI session; resumes target this id, never `claude --continue`.
  status      String      @default("running") // running | exited | killed | error
  exitCode    Int?
  startedAt   DateTime    @default(now())
  endedAt     DateTime?

  logs        RunLog[]

  @@index([dockOpen])
}

// Key/value store for persisted UI state (dock size, selected project, view,
// last-open editor file, …). One row per key; value is a JSON string.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model RunLog {
  id     String   @id @default(cuid())
  runId  String
  run    Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  chunk  String
  ts     DateTime @default(now())

  @@index([runId, ts])
}

model Analysis {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rawResult  Json     // full JSON returned by claude -p
  createdAt  DateTime @default(now())
}

// End-of-Day snapshot: what a project finished on a given day. Compiled on
// demand (button) into one row per project per day. Retention: keep the newest
// 10 days per project; older ones are pruned on each compile.
model EodEntry {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  day       String   // local date key 'YYYY-MM-DD' — one EOD per project per day
  items     String   // JSON array snapshot of finished runs that day
  note      String?  // user-editable free-text note
  summary   String?  // AI-generated narrative (claude -p), on demand
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, day])
  @@index([projectId, day])
}

// SGA Release: one release-zip build of the SG Claude Assistant repo (bump the
// three version files → git-archive zip → AI patch notes). The zip lands at
// ~/sgen-claude-chat-v<version>.zip; summary/notes are generated on demand
// (claude -p) after the zip and stay re-copyable from the history.
model Release {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version       String   // SemVer the release was cut as (also in the zip filename)
  zipPath       String   // absolute path of the produced zip
  zipBytes      Int
  headCommit    String?  // repo HEAD at build time — next release's git-log boundary
  dirtyIncluded Boolean  @default(false) // uncommitted changes were knowingly shipped
  summary       String?  // Patch Note Summary (plain-language, AI)
  notes         String?  // Patch Note Description (one line per change, AI)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId, createdAt])
}

// End-of-Day REPORT: one cross-project markdown report per day, generated (AI)
// from the projects active that day (Claude sessions native+NARUKAMI, runs, git
// commits). Distinct from EodEntry (the older per-project run snapshot).
model EodReport {
  id        String   @id @default(cuid())
  day       String   @unique // local 'YYYY-MM-DD' — one report per day
  markdown  String   // the generated report (template format)
  projects  String   // JSON array of { name, path } included in the report
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
