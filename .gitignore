node_modules/
dist/
build/

# build outputs (regenerated by build; huge / platform-specific)
packages/desktop/release/
packages/desktop/dist-app/
packages/desktop/dist-main/
# Prisma client is regenerated by backend postinstall (`prisma generate`)
packages/backend/src/generated/

# secrets / local config
.env
.env.local
.runner-token
packages/backend/.env
packages/frontend/.env
# per-machine Claude Code settings (absolute paths, personal statusLine, etc.)
.claude/settings.local.json

# logs / os
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# SQLite WAL sidecars (journal_mode=WAL is set at boot; only dev.db is tracked)
*.db-wal
*.db-shm
# single-instance advisory lock
.narukami.lock

# packaged archives / large artifacts
*.zip

# Code Map engine (codebase-memory-mcp) per-repo shareable graph artifact
.codebase-memory/
.cbmignore

# runtime session-wrapup logs (routes/runs.ts appendWrapupLog)
/logs/
